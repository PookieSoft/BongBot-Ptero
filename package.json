{
    "name": "bongbot-ptero",
    "version": "0.1.0",
    "description": "BongBot Pterodactyl Server Management",
    "main": "./dist/index.js",
    "type": "module",
    "scripts": {
        "build": "node esbuild.config.mjs --minify",
        "build-dev": "docker build -f ./Dockerfile --build-arg CORE_SOURCE=file:/core .. -t bongbot-ptero && docker run --rm --env-file .env --volume ./data:/app/data --volume ./logs:/app/logs bongbot-ptero",
        "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --json --coverage --outputFile=report.json --passWithNoTests --silent",
        "prepare": "npx tsc -p tsconfig.lib.json --noCheck"
    },
    "dependencies": {
        "bongbot-core": "github:Mirasii/BongBot-Core#main"
    },
    "devDependencies": {
        "@types/better-sqlite3": "^7.6.13",
        "@types/jest": "^30.0.0",
        "better-sqlite3": "^12.8.0",
        "cross-env": "^10.1.0",
        "discord.js": "^14.25.1",
        "esbuild": "^0.27.2",
        "jest": "^30.2.0",
        "jest-junit": "^16.0.0",
        "msw": "^2.12.14",
        "ts-jest": "^29.4.6",
        "ts-jest-resolver": "^2.0.1",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3"
    }
}
